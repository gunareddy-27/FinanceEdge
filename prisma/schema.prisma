// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  country       String
  incomeBracket String         @map("income_bracket") // low, middle, high
  currency      String         @default("INR")
  theme         String         @default("system") // light, dark, system, finance_green
  transactions  Transaction[]
  budgets       Budget[]
  taxEstimates  TaxEstimate[]
  reports       Report[]
  subscriptions Subscription[]
  goals         Goal[]
  expenseGroups ExpenseGroup[]

  @@map("users")
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   // income or expense
  category  String
  amount    Decimal
  date      DateTime
  description String?
  voiceNotes  String?  @map("voice_notes")
  attachmentUrl String?  @map("attachment_url")
  fromDest    String?  @map("from_dest")
  toDest      String?  @map("to_dest")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Budget {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  category  String
  limit     Decimal
  month     String   // Format: "YYYY-MM"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model TaxEstimate {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  quarter      String   // Q1, Q2, Q3, Q4
  year         Int
  estimatedTax Decimal  @map("estimated_tax")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tax_estimates")
}

model Report {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  period     String
  reportType String   @map("report_type")
  filePath   String?  @map("file_path")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  amount    Decimal
  frequency String   // monthly, yearly
  status    String   @default("active") // active, inactive
  nextDate  DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Goal {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String
  targetAmount Decimal  @map("target_amount")
  currentAmount Decimal @default(0) @map("current_amount")
  deadline     DateTime
  status       String   @default("active")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model ExpenseGroup {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  name        String
  totalAmount Decimal       @map("total_amount")
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     GroupMember[]

  @@map("expense_groups")
}

model GroupMember {
  id             Int          @id @default(autoincrement())
  groupId        Int          @map("group_id")
  name           String
  shareAmount    Decimal      @map("share_amount")
  isPaid         Boolean      @default(false) @map("is_paid")
  expenseGroup   ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_members")
}
